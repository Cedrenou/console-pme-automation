# Variables d'environnement pour le développement local
# Copier ce fichier vers .env.local et ajuster les valeurs

# Environnement
NEXT_PUBLIC_ENVIRONMENT=development

# URL de l'API (pour le développement local)
# NEXT_PUBLIC_API_URL=https://dev-api.execute-api.eu-west-3.amazonaws.com/dev

# Variables Supabase (à ajouter lors de la migration)
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Middleware Rezomatic ↔ Shopify (utilisé par /api/shopify-import — server-side uniquement)
# Cf. page /shopify-catalogue. À configurer côté Amplify pour la prod.
# SHOPIFY_MIDDLEWARE_URL=https://connector.sunsetridershop.com
# SHOPIFY_MIDDLEWARE_ADMIN_PASSWORD=<copier depuis le .env du middleware EC2>
